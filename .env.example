# PostgreSQL
POSTGRES_DB=vivaz
POSTGRES_USER=vivaz
POSTGRES_PASSWORD=cambia-esto

# Directus
DIRECTUS_KEY=replace-with-random-value
DIRECTUS_SECRET=replace-with-random-value
DIRECTUS_ADMIN_EMAIL=admin@platosvivaz.com
DIRECTUS_ADMIN_PASSWORD=cambia-esto

# Admin Token (para setup-schema.js y seed-data.js)
ADMIN_TOKEN=replace-with-static-token

# URLs publicas (produccion detras de nginx-proxy)
DIRECTUS_HOST=cms.platosvivaz.com
DIRECTUS_PUBLIC_URL=https://cms.platosvivaz.com
FRONTEND_HOST=platosvivaz.com
NEXT_PUBLIC_SITE_URL=https://platosvivaz.com

# CORS (separar con comas si necesitas varios origenes)
CORS_ORIGIN=https://platosvivaz.com

# Content-Security-Policy: permitir iframe desde Directus (Visual Editor)
NEXT_PUBLIC_DIRECTUS_URL=https://cms.platosvivaz.com

# Resend (email notifications for contact form)
RESEND_API_KEY=re_xxxx
ADMIN_EMAIL=admin@platosvivaz.com
RESEND_FROM_EMAIL=onboarding@resend.dev
